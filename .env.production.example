# Copy this file to `.env` in this same directory (next to docker-compose.yml)
# before running `docker compose up` on the server. `.env` is already gitignored
# — never commit it.
#
# The values previously hardcoded in docker-compose.yml (APP_KEY, DB_PASSWORD,
# MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD) were committed to git history and must be
# treated as permanently compromised. Do not reuse them here — generate fresh
# values below.

# Laravel application encryption key (encrypts sessions, cookies, and any
# encrypted DB columns). Generate a new one with:
#   docker compose run --rm app php artisan key:generate --show
# then paste the full "base64:...." value below.
APP_KEY=

# Password for the MySQL "maditam" application user. Used by both the `app`
# service (as DB_PASSWORD) and the `db` service (as MYSQL_PASSWORD) — this is
# intentionally a single value so the two can never drift out of sync.
DB_PASSWORD=

# MySQL root password.
MYSQL_ROOT_PASSWORD=
